# =============================================================================
# Snackoh Bakers Management System - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# IMPORTANT: Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
# Get these from your Supabase project dashboard: Settings > API
# Docs: https://supabase.com/docs/guides/getting-started
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------------------------------
# Site URL
# -----------------------------------------------------------------------------
# The public URL of your deployed site (used for M-Pesa callbacks and redirects).
# For local development, use http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# M-Pesa C2B Configuration (Customer Payments via Family Bank Paybill)
# -----------------------------------------------------------------------------
# Register for Daraja API access at https://developer.safaricom.co.ke/
# For Family Bank integration, use the Paybill number provided by Family Bank.
# Use "sandbox" for testing, "production" for live payments.
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_PASSKEY=your-passkey
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback
# Transaction type: CustomerPayBillOnline (Paybill) or CustomerBuyGoodsOnline (Till)
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline

# -----------------------------------------------------------------------------
# M-Pesa B2C Configuration (Disbursements - Refunds, Salary, Promotions)
# -----------------------------------------------------------------------------
# Required for sending money from your business to customers via M-Pesa.
# Supports: SalaryPayment, BusinessPayment, PromotionPayment
# Uses M-Pesa B2C API v3 for secure, reliable disbursements.
MPESA_B2C_SHORTCODE=your-b2c-shortcode
MPESA_B2C_INITIATOR_NAME=your-initiator-name
MPESA_B2C_SECURITY_CREDENTIAL=your-encrypted-security-credential
MPESA_B2C_CONSUMER_KEY=your-b2c-consumer-key
MPESA_B2C_CONSUMER_SECRET=your-b2c-consumer-secret
MPESA_B2C_RESULT_URL=https://your-domain.com/api/mpesa/b2c/result
MPESA_B2C_TIMEOUT_URL=https://your-domain.com/api/mpesa/b2c/timeout
